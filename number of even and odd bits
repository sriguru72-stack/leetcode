class Solution {
    public int[] evenOddBit(int n) {
        int evencount=0,oddcount=0;
        int num1;
        int index=0;
        while(n>0){
            num1= n&1;
            if(num1==1){
            if(index%2==0){
                evencount++;
            }else{
                oddcount++;
            }
            }
            index++;
            n>>=1;
        }
        return new int[]{evencount, oddcount};
    }
}

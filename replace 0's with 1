import java.util.*;
class replacezero{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        String num="12090";
        char[] chars = num.toCharArray();
        for(int i=0;i<num.length();i++){
            if(chars[i]=='0'){
                chars[i]='1';
            }
        }
        num = new String(chars);
        System.out.println(num);
    }
}

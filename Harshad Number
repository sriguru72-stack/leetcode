class Solution {
    public int sumOfTheDigitsOfHarshadNumber(int x) {
        int orginalvalue=x;
        int num=0;
        while(x!=0){
            int rev=x%10;
            num=num+rev;
            x=x/10;
        }
        if(orginalvalue%num==0){
                return num;
        }
        else{
            return -1;
        }
        
    }
}

import java.util.*;
class hcf{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        while(a!=0 && b!=0){
        if(a>b){
            a=a%b;
        }else if(b>a){
            b=b%a;
        }
        }
        if(a!=0){
        System.out.println(a);
        }else{
            System.out.println(b);
        }
    }
}
